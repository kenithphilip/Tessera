# WireGuard peer configuration for a single Tessera mesh node.
# Generated by tessera.runtime.tetragon.WireGuardConfig.render()
# DO NOT commit a file with real private keys. This is an example only.
#
# Replace all placeholder values before use.
# Protect the deployed file with mode 0600.

[Interface]
# Private key for this node. Generate with: wg genkey
PrivateKey = REPLACE_WITH_WG_PRIVATE_KEY_BASE64=
# WireGuard interface IP in the mesh CIDR.
Address = 10.200.0.1/24
ListenPort = 51820
# Optional: cluster DNS server(s) reachable through the tunnel.
DNS = 10.96.0.10

[Peer]
# Public key of the peer node. Generate with: echo $PRIVKEY | wg pubkey
PublicKey = REPLACE_WITH_PEER_WG_PUBLIC_KEY_BASE64=
# Optional pre-shared key for quantum-resistance. Generate with: wg genpsk
# PresharedKey = REPLACE_WITH_WG_PRESHARED_KEY_BASE64=
# Traffic destined for the peer's mesh IP routes through the tunnel.
AllowedIPs = 10.200.0.2/32
# Public endpoint of the peer node (host or IP + port).
Endpoint = peer-node.tessera.example.com:51820
# Keep the tunnel alive through NAT. 25 seconds is typical.
PersistentKeepalive = 25
